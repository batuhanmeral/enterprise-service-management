# Copy to .env and fill in real values. Never commit .env.
# Generate a key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-50-char-random-string

# Set DEBUG=False in any deployed environment.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Required when serving over HTTPS behind a proxy, e.g. https://dispatch.example.com
CSRF_TRUSTED_ORIGINS=

# Database. DB_HOST is overridden to "db" by docker-compose.
DB_NAME=dispatch_db
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=localhost
DB_PORT=5432

# Optional HTTPS hardening (only applied when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
